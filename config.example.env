# =====================================================================
#  CONFIGURACION DE ViroFeed AI Personal
# ---------------------------------------------------------------------
#  COMO USAR ESTE ARCHIVO:
#  1. Haz una copia de este archivo y llamala  .env  (sin nombre, solo .env)
#  2. Pega tus claves donde dice "PEGA_AQUI..."
#  3. Guarda el archivo.
#
#  NUNCA compartas tu archivo .env con nadie: contiene tus claves secretas.
# =====================================================================

# --- 1) GROQ (genera el guion con IA, GRATIS) ---------------------------
# Consigue tu clave gratis en: https://console.groq.com  (API Keys)
GROQ_API_KEY=PEGA_AQUI_TU_CLAVE_DE_GROQ

# Modelo de IA a usar (puedes dejarlo asi)
GROQ_MODEL=llama-3.3-70b-versatile

# --- 2) PEXELS (descarga imagenes, GRATIS) ------------------------------
# Consigue tu clave gratis en: https://www.pexels.com/api/
PEXELS_API_KEY=PEGA_AQUI_TU_CLAVE_DE_PEXELS

# --- 3) PIXABAY (imagenes alternativas, opcional y GRATIS) --------------
# Opcional. Si lo dejas vacio, se usaran las otras fuentes.
# Consigue tu clave gratis en: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# --- 3b) UNSPLASH (fotos profesionales, opcional y GRATIS) --------------
# Fotos muy bonitas estilo "revista". Opcional pero recomendado.
# Consigue tu clave gratis asi:
#   1. Entra a:  https://unsplash.com/developers
#   2. Crea una cuenta y registra una "New Application" (acepta los terminos).
#   3. Copia el valor "Access Key" y pegalo aqui abajo.
UNSPLASH_ACCESS_KEY=

# --- 3c) OPENVERSE (700M+ imagenes, GRATIS y SIN CLAVE) -----------------
# No necesitas configurar nada: Openverse funciona automaticamente y sirve
# de respaldo para que SIEMPRE haya imagenes, aunque no pongas otras claves.

# --- 4) VOZ EN ESPANOL ---------------------------------------------------
# Si pones TTS_VOICE=random, el programa ROTARA las voces del grupo VOICE_POOL
# automaticamente (un video con una voz, el siguiente con otra, etc.).
# Tambien puedes elegir "Voz automatica" desde la pagina sin tocar esto.
#
# Voces recomendadas:
#   es-MX-DaliaNeural    (mujer, Mexico)
#   es-MX-JorgeNeural    (hombre, Mexico)
#   es-ES-ElviraNeural   (mujer, Espana)
#   es-ES-AlvaroNeural   (hombre, Espana)
#   es-AR-ElenaNeural    (mujer, Argentina)
#   es-CO-SalomeNeural   (mujer, Colombia)
TTS_VOICE=random

# Velocidad de la voz (ej: +0% normal, +10% mas rapido, -10% mas lento)
TTS_RATE=+8%

# Grupo de voces para el modo automatico (separadas por comas).
# El programa va rotando entre estas en cada video. Puedes cambiarlas,
# quitar o agregar las que quieras (mezcla hombres y mujeres).
VOICE_POOL=es-MX-JorgeNeural,es-MX-DaliaNeural,es-ES-AlvaroNeural,es-ES-ElviraNeural,es-CO-SalomeNeural

# --- 5) AVATAR (interruptor ON/OFF) -------------------------------------
# false = videos faceless (solo imagenes + voz + subtitulos) GRATIS e ILIMITADO
# true  = activa el avatar hablando (usa servicio en la nube, con limite)
AVATAR_ENABLED=false

# Proveedor del avatar cuando AVATAR_ENABLED=true  (de momento: did)
AVATAR_PROVIDER=did
# Clave del proveedor de avatar (solo si activas el avatar)
DID_API_KEY=

# --- 6) AJUSTES DEL VIDEO ------------------------------------------------
# Duracion objetivo del video en segundos (30, 45 o 60)
VIDEO_DURATION=45
# Tipo de guion: resumen | breaking | top3
SCRIPT_STYLE=breaking
# Llamada a la accion al final del video
CALL_TO_ACTION=Sigueme para mas noticias

# Sincronia de subtitulos: cuanto ADELANTAR los subtitulos respecto a la voz,
# en segundos. Si los notas ATRASADOS (aparecen despues de que se dice la
# palabra), SUBE este numero (ej. 0.35). Si se adelantan de mas, BAJALO.
SUBTITLE_LEAD=0.25

# --- 7) FUENTE DE LAS IMAGENES ------------------------------------------
# Como conseguir las imagenes que concuerdan con la narracion:
#   stock  = fotos reales de Pexels/Pixabay por palabra clave. (RECOMENDADO: rapido)
# (Las opciones con IA se quitaron porque tardaban mucho y salian con errores.)
IMAGE_SOURCE=stock

# --- 8) TOGETHER AI / FLUX (imagenes realistas, RECOMENDADO) ------------
# FLUX es la IA #1 en realismo y genera directo en vertical 9:16.
# Consigue tu clave GRATIS asi:
#   1. Entra a:  https://api.together.ai
#   2. Crea una cuenta gratis (puedes entrar con Google).
#   3. Ve a la seccion "API Keys" y copia tu clave.
#   4. Pegala aqui abajo (reemplaza el texto PEGA_AQUI...).
TOGETHER_API_KEY=PEGA_AQUI_TU_CLAVE_DE_TOGETHER
# Modelo de imagen gratuito (puedes dejarlo asi).
TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell-Free

# --- 9) GEMINI / NANO BANANA (imagenes realistas, opcional) -------------
# Consigue tu clave GRATIS en: https://aistudio.google.com/apikey
# Solo se usa si eliges IMAGE_SOURCE=gemini (o el modo Gemini en la pagina).
GEMINI_API_KEY=
# Modelo de imagen (puedes dejarlo asi). Alternativa pro: gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
